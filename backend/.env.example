# ============================================
# FILE .env.example
# ============================================
# Đây là file mẫu để show các biến môi trường cần thiết
# Tạo file .env từ file này và điền thông tin thực tế
# 
# HỌC DỮ LIỆU CẦN ĐIỀN:
# DATABASE_URL: Đường dẫn kết nối PostgreSQL
# DEBUG: Chế độ debug (True/False)
# 
# Cách sử dụng:
# 1. Copy file này thành .env
# 2. Điền các giá trị thực tế
# 3. Chạy ứng dụng
# 
# LƯU Ý: KHÔNG commit file .env lên Git vì chứa mật khẩu!
#       Chỉ commit file .env.example


# ============================================
# CẤU HÌNH DATABASE
# ============================================
# Định dạng: postgresql://user:password@host:port/database_name
# Ví dụ:
# - Localhost: postgresql://postgres:password@localhost:5432/gym_management
# - Docker: postgresql://postgres:password@postgres:5432/gym_management
# - Production: postgresql://user:complex_password@db.example.com:5432/gym_management

DATABASE_URL=postgresql://postgres:password@localhost:5432/gym_management


# ============================================
# CẤU HÌNH ỨNG DỤNG
# ============================================
# DEBUG: Bật/tắt chế độ debug
# - True: Hiển thị chi tiết lỗi (dành cho development)
# - False: Ẩn chi tiết lỗi (dành cho production)

DEBUG=True


# ============================================
# CẤU HÌNH API
# ============================================
# API_HOST: Địa chỉ máy chủ API
# API_PORT: Cổng API

API_HOST=0.0.0.0
API_PORT=8000


# ============================================
# CẤU HÌNH FRONTEND
# ============================================
# Các đường dẫn frontend được phép gọi API (CORS)

FRONTEND_URL=http://localhost:3000
FRONTEND_URL_DEV=http://localhost:5173
